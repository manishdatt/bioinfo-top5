---
import { getCollection } from "astro:content";
import NewsCard from "../components/NewsCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsEntryLayout from "../layouts/NewsEntryLayout.astro";

const newsPosts = (await getCollection("news", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

if (newsPosts.length === 0) {
  throw new Error("No published entries found in src/content/news.");
}

const [latestPost, ...previousPosts] = newsPosts;
const { Content } = await latestPost.render();

const parsedItems = Array.from(
  latestPost.body.matchAll(/##\s+(.+?)\r?\n\r?\n([\s\S]*?)(?=(\r?\n##\s+)|$)/g),
).map((match) => ({
  title: match[1].trim(),
  description: match[2].trim().replace(/\r?\n+/g, " "),
}));
---

<BaseLayout title="Latest Weekly Brief" description={latestPost.data.description}>
  <NewsEntryLayout
    title={latestPost.data.title}
    weekNumber={latestPost.data.weekNumber}
    pubDate={latestPost.data.pubDate}
    summary={latestPost.data.summary}
    contentClass="mt-6 grid grid-cols-1 gap-4"
  >
    {
      parsedItems.length > 0 ? (
        parsedItems.map((item) => (
          <article
            class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition duration-200 ease-out hover:-translate-y-0.5 hover:shadow-md dark:border-slate-800 dark:bg-slate-900"
          >
            <h3 class="font-serif text-xl font-semibold text-slate-900 dark:text-slate-100">{item.title}</h3>
            <p class="mt-3 text-base leading-7 text-slate-700 dark:text-slate-300">{item.description}</p>
          </article>
        ))
      ) : (
        <div class="prose prose-slate max-w-none lg:prose-xl dark:prose-invert">
          <Content />
        </div>
      )
    }
  </NewsEntryLayout>

  <section id="previous-weeks" class="mt-14">
    <h2 class="font-serif text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-100">
      Previous Weeks
    </h2>
    {
      previousPosts.length > 0 ? (
        <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {previousPosts.map((post) => (
            <NewsCard
              slug={post.slug}
              title={post.data.title}
              weekNumber={post.data.weekNumber}
              pubDate={post.data.pubDate}
            />
          ))}
        </div>
      ) : (
        <p class="mt-4 text-sm text-slate-600 dark:text-slate-300">No previous weeks yet.</p>
      )
    }
  </section>
</BaseLayout>
