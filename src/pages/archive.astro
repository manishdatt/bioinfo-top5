---
import { getCollection } from "astro:content";
import NewsCard from "../components/NewsCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const newsPosts = (await getCollection("news", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout
  title="Archive"
  description="Browse previous Bioinfo Top 5 weekly editions."
>
  <section>
    <h1 class="font-serif text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
      Archive
    </h1>
    <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">
      Every weekly edition in one place.
    </p>
    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {newsPosts.map((post) => (
        <NewsCard
          slug={post.slug}
          title={post.data.title}
          weekNumber={post.data.weekNumber}
          pubDate={post.data.pubDate}
        />
      ))}
    </div>
  </section>
</BaseLayout>
