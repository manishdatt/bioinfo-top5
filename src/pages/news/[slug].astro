---
import { getCollection } from "astro:content";
import { marked } from "marked";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsEntryLayout from "../../layouts/NewsEntryLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("news", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"news"> };
const { Content } = await post.render();

const parsedItems = Array.from(
  post.body.matchAll(/##\s+(.+?)\r?\n\r?\n([\s\S]*?)(?=(\r?\n##\s+)|$)/g),
).map((match) => ({
  title: match[1].trim(),
  descriptionHtml: marked.parse(match[2].trim()),
}));
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <NewsEntryLayout
    title={post.data.title}
    weekNumber={post.data.weekNumber}
    pubDate={post.data.pubDate}
    summary={post.data.summary}
    contentClass="mt-6 grid grid-cols-1 gap-4"
  >
    {
      parsedItems.length > 0 ? (
        parsedItems.map((item) => (
          <article
            class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition duration-200 ease-out hover:-translate-y-0.5 hover:shadow-md dark:border-slate-800 dark:bg-slate-900"
          >
            <h3 class="font-serif text-xl font-semibold text-slate-900 dark:text-slate-100">{item.title}</h3>
            <div class="mt-3 text-base leading-7 text-slate-700 dark:text-slate-300" set:html={item.descriptionHtml} />
          </article>
        ))
      ) : (
        <div class="prose prose-slate max-w-none lg:prose-xl dark:prose-invert">
          <Content />
        </div>
      )
    }
  </NewsEntryLayout>
</BaseLayout>
