---
import { getIsoWeekRangeLabel } from "../utils/date";

interface Props {
  slug: string;
  title: string;
  weekNumber: number;
  pubDate: Date;
}

const { slug, title, weekNumber, pubDate } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(pubDate);
const dateRange = getIsoWeekRangeLabel(weekNumber, pubDate.getUTCFullYear());
---

<a
  href={`/news/${slug}/`}
  class="block rounded-xl border border-slate-200 bg-white p-5 transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-sm dark:border-slate-800 dark:bg-slate-900 dark:hover:border-slate-700"
>
  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">
    {dateRange}
  </p>
  <h3 class="mt-2 text-base font-semibold text-slate-900 dark:text-slate-100">{title}</h3>
  <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">{formattedDate}</p>
</a>
