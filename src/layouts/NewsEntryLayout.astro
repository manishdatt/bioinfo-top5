---
import { getIsoWeekRangeLabel } from "../utils/date";

interface Props {
  title: string;
  weekNumber: number;
  pubDate: Date;
  summary?: string;
  contentClass?: string;
}

const {
  title,
  weekNumber,
  pubDate,
  summary,
  contentClass = "prose prose-slate mt-8 max-w-none lg:prose-xl dark:prose-invert",
} = Astro.props;

const dateRange = getIsoWeekRangeLabel(weekNumber, pubDate.getUTCFullYear());
---

<article>
  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">
    {dateRange}
  </p>
  <h1 class="mt-2 font-serif text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
    {title}
  </h1>
  <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
    {pubDate.toLocaleDateString("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
    })}
  </p>

  {
    summary && (
      <p class="mt-6 text-base leading-7 text-slate-700 dark:text-slate-300">
        {summary}
      </p>
    )
  }
  <div class:list={["news-content", contentClass]}>
    <slot />
  </div>
</article>
